# Database
DATABASE_URL="postgresql://change-me:change-me@localhost:5432/campaign_hub"

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# JWT
# Generate with: openssl rand -base64 64 (recommended, min 32 chars)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis / Realtime / Metrics
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:4200
# Optional: if set, /metrics also accepts this token via x-metrics-token
METRICS_TOKEN=

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# CORS
CORS_ORIGIN=http://localhost:4200
