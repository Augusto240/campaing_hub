generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum CampaignRole {
  GM
  PLAYER
}

enum EventType {
  BATTLE
  STORY
  NPC
  TREASURE
}

enum Rarity {
  MUNDANE
  COMMON
  UNCOMMON
  RARE
  VERY_RARE
  LEGENDARY
  ARTIFACT
  ELDRITCH
}

enum ItemType {
  WEAPON
  ARMOR
  POTION
  SCROLL
  WAND
  RING
  MISC
  MAGIC_ITEM
  CONSUMABLE
  TOME
  MYTHOS_TOME
  RELIC
}

enum WikiCategory {
  NPC
  LOCATION
  FACTION
  LORE
  HOUSE_RULE
  BESTIARY
  DEITY
  MYTHOS
  SESSION_RECAP
  CHARACTER
  EVENT
  ITEM
  QUEST
  TIMELINE
}

enum ProposalStatus {
  OPEN
  DECIDED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  ownedCampaigns  Campaign[]
  campaignMembers CampaignMember[]
  characters      Character[]
  notifications   Notification[]
  activityLogs    ActivityLog[]
  createdSessions Session[]
  refreshTokens   RefreshToken[]
  wikiPages       WikiPage[]       @relation("WikiPageAuthor")
  diceRolls       DiceRoll[]
  creatures       Creature[]       @relation("CreatureAuthor")
  sessionProposals SessionProposal[] @relation("SessionProposalAuthor")
  sessionVotes    SessionVote[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  revoked   Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token, revoked])
  @@map("refresh_tokens")
}

model RpgSystem {
  id              String   @id @default(uuid())
  name            String   @unique
  slug            String   @unique
  description     String?
  diceFormula     String   @map("dice_formula")
  attributeSchema Json     @map("attribute_schema")
  xpTable         Json?    @map("xp_table")
  hasSpellSlots   Boolean  @default(false) @map("has_spell_slots")
  hasSanity       Boolean  @default(false) @map("has_sanity")
  hasMana         Boolean  @default(false) @map("has_mana")
  hasHeroPoints   Boolean  @default(false) @map("has_hero_points")
  createdAt       DateTime @default(now()) @map("created_at")

  campaigns        Campaign[]
  characters       Character[]
  items            Item[]
  creatures        Creature[]
  spells           Spell[]
  characterClasses CharacterClass[]
  ancestries       Ancestry[]
  conditions       Condition[]
  feats            Feat[]
  backgrounds      Background[]

  @@map("rpg_systems")
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  description String?
  system      String
  systemId    String?  @map("system_id")
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  owner            User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  systemTemplate   RpgSystem?       @relation(fields: [systemId], references: [id], onDelete: SetNull)
  members          CampaignMember[]
  characters       Character[]
  sessions         Session[]
  events           Event[]
  wikiPages        WikiPage[]
  diceRolls        DiceRoll[]
  sessionProposals SessionProposal[]
  gameMaps         GameMap[]

  @@map("campaigns")
}

model CampaignMember {
  id         String       @id @default(uuid())
  campaignId String       @map("campaign_id")
  userId     String       @map("user_id")
  role       CampaignRole
  joinedAt   DateTime     @default(now()) @map("joined_at")

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("campaign_members")
}

model Character {
  id           String   @id @default(uuid())
  name         String
  class        String
  level        Int      @default(1)
  xp           Int      @default(0)
  version      Int      @default(0)
  playerId     String   @map("player_id")
  campaignId   String   @map("campaign_id")
  systemId     String?  @map("system_id")
  attributes   Json     @default("{}")
  resources    Json     @default("{}")
  inventory    Json     @default("[]")
  notes        String?
  imageUrl     String?  @map("image_url")
  sheetFileUrl String?  @map("sheet_file_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  player         User          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  campaign       Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  systemTemplate RpgSystem?    @relation(fields: [systemId], references: [id], onDelete: SetNull)
  loot           Loot[]
  sanityEvents   SanityEvent[]
  spellCasts     SpellCast[]
  diceRolls      DiceRoll[]
  combatants     Combatant[]
  mapTokens      MapToken[]

  @@map("characters")
}

model Session {
  id             String   @id @default(uuid())
  campaignId     String   @map("campaign_id")
  date           DateTime
  summary        String?
  narrativeLog   String?  @map("narrative_log")
  privateGmNotes String?  @map("private_gm_notes")
  highlights     String[] @default([])
  xpAwarded      Int      @default(0) @map("xp_awarded")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator      User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  loot         Loot[]
  diceRolls    DiceRoll[]
  sanityEvents SanityEvent[]
  spellCasts   SpellCast[]
  combatEncounters CombatEncounter[]

  @@map("sessions")
}

model CombatEncounter {
  id          String      @id @default(uuid())
  sessionId   String      @map("session_id")
  name        String
  isActive    Boolean     @default(true) @map("is_active")
  currentTurn Int         @default(0) @map("current_turn")
  round       Int         @default(1)
  createdAt   DateTime    @default(now()) @map("created_at")

  session     Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  combatants  Combatant[]

  @@map("combat_encounters")
}

model Combatant {
  id          String          @id @default(uuid())
  encounterId String          @map("encounter_id")
  name        String
  initiative  Int
  hp          Int
  maxHp       Int             @map("max_hp")
  isNpc       Boolean         @default(false) @map("is_npc")
  characterId String?         @map("character_id")
  conditions  String[]        @default([])
  notes       String?
  order       Int

  encounter   CombatEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  character   Character?      @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([encounterId, order])
  @@map("combatants")
}

model Loot {
  id                    String   @id @default(uuid())
  name                  String
  description           String?
  value                 Float    @default(0)
  sessionId             String   @map("session_id")
  assignedToCharacterId String?  @map("assigned_to_character_id")
  createdAt             DateTime @default(now()) @map("created_at")

  // Relations
  session             Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignedToCharacter Character? @relation(fields: [assignedToCharacterId], references: [id], onDelete: SetNull)
  lootItems           LootItem[]

  @@map("loot")
}

model Item {
  id          String   @id @default(uuid())
  name        String
  description String?
  rarity      Rarity   @default(COMMON)
  weight      Float?
  value       Int?
  itemType    ItemType @default(MISC) @map("item_type")
  systemId    String?  @map("system_id")
  properties  Json?
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")

  systemTemplate RpgSystem? @relation(fields: [systemId], references: [id], onDelete: SetNull)
  lootItems      LootItem[]

  @@map("items")
}

model LootItem {
  id       String @id @default(uuid())
  lootId   String @map("loot_id")
  itemId   String @map("item_id")
  quantity Int    @default(1)

  loot Loot @relation(fields: [lootId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([lootId, itemId])
  @@map("loot_items")
}

model Event {
  id          String    @id @default(uuid())
  campaignId  String    @map("campaign_id")
  title       String
  description String?
  eventDate   DateTime  @map("event_date")
  type        EventType
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("events")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  message   String
  read      Boolean   @default(false)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model WikiPage {
  id         String       @id @default(uuid())
  campaignId String       @map("campaign_id")
  title      String
  content    String
  category   WikiCategory
  tags       String[]     @default([])
  createdBy  String       @map("created_by")
  isPublic   Boolean      @default(true) @map("is_public")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  // Hierarchical structure (Notion-like)
  parentId   String?      @map("parent_id")
  icon       String?      // emoji or icon name
  coverImage String?      @map("cover_image")
  position   Int          @default(0)
  isFavorite Boolean      @default(false) @map("is_favorite")

  campaign   Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author     User         @relation("WikiPageAuthor", fields: [createdBy], references: [id], onDelete: Cascade)
  parent     WikiPage?    @relation("WikiPageHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children   WikiPage[]   @relation("WikiPageHierarchy")
  blocks     WikiBlock[]
  outgoingLinks WikiBacklink[] @relation("WikiBacklinkSource")
  incomingLinks WikiBacklink[] @relation("WikiBacklinkTarget")

  @@index([campaignId, category])
  @@index([parentId])
  @@map("wiki_pages")
}

// Block-based content (Notion-like editor)
enum WikiBlockType {
  TEXT
  HEADING_1
  HEADING_2
  HEADING_3
  BULLETED_LIST
  NUMBERED_LIST
  TODO
  TOGGLE
  QUOTE
  CALLOUT
  CODE
  DIVIDER
  IMAGE
  LINK_TO_PAGE
  EMBED
}

model WikiBlock {
  id         String        @id @default(uuid())
  pageId     String        @map("page_id")
  type       WikiBlockType
  content    Json          // flexible content based on type
  position   Int           @default(0)
  indent     Int           @default(0)
  isChecked  Boolean?      @map("is_checked") // for TODO blocks
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, position])
  @@map("wiki_blocks")
}

// Backlinks for wiki pages (knowledge graph)
model WikiBacklink {
  id           String   @id @default(uuid())
  sourcePageId String   @map("source_page_id")
  targetPageId String   @map("target_page_id")
  context      String?  // surrounding text snippet
  createdAt    DateTime @default(now()) @map("created_at")

  sourcePage WikiPage @relation("WikiBacklinkSource", fields: [sourcePageId], references: [id], onDelete: Cascade)
  targetPage WikiPage @relation("WikiBacklinkTarget", fields: [targetPageId], references: [id], onDelete: Cascade)

  @@unique([sourcePageId, targetPageId])
  @@index([targetPageId])
  @@map("wiki_backlinks")
}

// Templates for wiki pages
model WikiTemplate {
  id          String       @id @default(uuid())
  name        String
  description String?
  category    WikiCategory
  icon        String?
  blocks      Json         // array of block structures
  createdBy   String       @map("created_by")
  isPublic    Boolean      @default(true) @map("is_public")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("wiki_templates")
}

// ===========================================
// VTT (Virtual Tabletop) Models
// ===========================================

enum GridType {
  SQUARE
  HEX_HORIZONTAL
  HEX_VERTICAL
  NONE
}

model GameMap {
  id           String    @id @default(uuid())
  campaignId   String    @map("campaign_id")
  name         String
  imageUrl     String    @map("image_url")
  width        Int       @default(1920)
  height       Int       @default(1080)
  gridType     GridType  @default(SQUARE) @map("grid_type")
  gridSize     Int       @default(50) @map("grid_size")
  gridColor    String    @default("#000000") @map("grid_color")
  gridOpacity  Float     @default(0.3) @map("grid_opacity")
  fogOfWar     Json?     @map("fog_of_war") // array of revealed areas
  walls        Json?     // array of wall segments for line of sight
  lights       Json?     // array of light sources
  isActive     Boolean   @default(false) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  campaign Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tokens   MapToken[]

  @@index([campaignId])
  @@map("game_maps")
}

model MapToken {
  id          String   @id @default(uuid())
  mapId       String   @map("map_id")
  name        String
  imageUrl    String?  @map("image_url")
  x           Float    @default(0)
  y           Float    @default(0)
  width       Int      @default(1) // in grid units
  height      Int      @default(1)
  rotation    Float    @default(0)
  isVisible   Boolean  @default(true) @map("is_visible")
  isLocked    Boolean  @default(false) @map("is_locked")
  layer       String   @default("tokens")
  conditions  String[] @default([])
  hp          Int?
  maxHp       Int?     @map("max_hp")
  aura        Json?    // aura effects
  vision      Json?    // vision settings (darkvision, etc)
  characterId String?  @map("character_id")
  creatureId  String?  @map("creature_id")
  controlledBy String[] @default([]) @map("controlled_by") // user IDs who can move

  map       GameMap    @relation(fields: [mapId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  creature  Creature?  @relation(fields: [creatureId], references: [id], onDelete: SetNull)

  @@index([mapId])
  @@map("map_tokens")
}

// ===========================================
// Compendium Models (5eTools-like)
// ===========================================

enum SpellSchool {
  ABJURATION
  CONJURATION
  DIVINATION
  ENCHANTMENT
  EVOCATION
  ILLUSION
  NECROMANCY
  TRANSMUTATION
  UNIVERSAL
}

enum MagicType {
  ARCANE
  DIVINE
  PRIMAL
  OCCULT
  UNIVERSAL
}

model Spell {
  id            String      @id @default(uuid())
  systemId      String      @map("system_id")
  name          String
  level         Int
  school        SpellSchool
  magicType     MagicType   @default(ARCANE) @map("magic_type")
  castingTime   String      @map("casting_time")
  range         String
  components    String
  duration      String
  description   String
  higherLevels  String?     @map("higher_levels")
  ritual        Boolean     @default(false)
  concentration Boolean     @default(false)
  classes       String[]    @default([])
  source        String?
  isHomebrew    Boolean     @default(false) @map("is_homebrew")
  createdBy     String?     @map("created_by")
  createdAt     DateTime    @default(now()) @map("created_at")

  systemTemplate RpgSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, name])
  @@index([systemId, level])
  @@index([school])
  @@map("spells")
}

model CharacterClass {
  id           String   @id @default(uuid())
  systemId     String   @map("system_id")
  name         String
  description  String
  hitDie       String   @map("hit_die")
  primaryAbility String @map("primary_ability")
  savingThrows String[] @default([]) @map("saving_throws")
  skills       String[] @default([])
  equipment    Json?
  features     Json     // class features by level
  subclasses   Json?    // available subclasses
  spellcasting Json?    // spellcasting rules
  source       String?
  isHomebrew   Boolean  @default(false) @map("is_homebrew")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  systemTemplate RpgSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, name])
  @@map("character_classes")
}

model Ancestry {
  id          String   @id @default(uuid())
  systemId    String   @map("system_id")
  name        String
  description String
  speed       Int      @default(30)
  size        String   @default("Medium")
  traits      Json     // racial traits
  languages   String[] @default([])
  subraces    Json?
  source      String?
  isHomebrew  Boolean  @default(false) @map("is_homebrew")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  systemTemplate RpgSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, name])
  @@map("ancestries")
}

model Condition {
  id          String   @id @default(uuid())
  systemId    String   @map("system_id")
  name        String
  description String
  effects     Json     // mechanical effects
  icon        String?
  color       String?  @default("#ff0000")
  source      String?
  createdAt   DateTime @default(now()) @map("created_at")

  systemTemplate RpgSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, name])
  @@map("conditions")
}

model Feat {
  id            String   @id @default(uuid())
  systemId      String   @map("system_id")
  name          String
  description   String
  prerequisites String?
  benefits      Json
  source        String?
  isHomebrew    Boolean  @default(false) @map("is_homebrew")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  systemTemplate RpgSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, name])
  @@map("feats")
}

model Background {
  id              String   @id @default(uuid())
  systemId        String   @map("system_id")
  name            String
  description     String
  skillProficiencies String[] @default([]) @map("skill_proficiencies")
  toolProficiencies String[] @default([]) @map("tool_proficiencies")
  languages       Int      @default(0)
  equipment       Json?
  feature         Json     // background feature
  suggestedCharacteristics Json? @map("suggested_characteristics")
  source          String?
  isHomebrew      Boolean  @default(false) @map("is_homebrew")
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  systemTemplate RpgSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, name])
  @@map("backgrounds")
}

model DiceRoll {
  id          String   @id @default(uuid())
  sessionId   String?  @map("session_id")
  campaignId  String   @map("campaign_id")
  userId      String   @map("user_id")
  characterId String?  @map("character_id")
  formula     String
  result      Int
  breakdown   Json
  label       String?
  isPrivate   Boolean  @default(false) @map("is_private")
  createdAt   DateTime @default(now()) @map("created_at")

  session   Session?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@map("dice_rolls")
}

model SanityEvent {
  id           String   @id @default(uuid())
  characterId  String   @map("character_id")
  sessionId    String?  @map("session_id")
  trigger      String
  sanityLost   Int      @map("sanity_lost")
  tempInsanity String?  @map("temp_insanity")
  permInsanity String?  @map("perm_insanity")
  createdAt    DateTime @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  session   Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([characterId, createdAt])
  @@map("sanity_events")
}

model SpellCast {
  id          String   @id @default(uuid())
  characterId String   @map("character_id")
  sessionId   String?  @map("session_id")
  spellName   String   @map("spell_name")
  manaCost    Int      @map("mana_cost")
  faithCost   Int      @default(0) @map("faith_cost")
  result      String?
  createdAt   DateTime @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  session   Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([characterId, createdAt])
  @@map("spell_casts")
}

model Creature {
  id           String    @id @default(uuid())
  name         String
  systemId     String    @map("system_id")
  creatureType String    @map("creature_type")
  stats        Json
  abilities    Json
  loot         Json?
  xpReward     Int?      @map("xp_reward")
  description  String?
  isPublic     Boolean   @default(false) @map("is_public")
  createdBy    String    @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  systemTemplate RpgSystem  @relation(fields: [systemId], references: [id], onDelete: Cascade)
  creator        User       @relation("CreatureAuthor", fields: [createdBy], references: [id], onDelete: Cascade)
  mapTokens      MapToken[]

  @@index([systemId, creatureType])
  @@unique([systemId, name])
  @@map("creatures")
}

model SessionProposal {
  id          String         @id @default(uuid())
  campaignId  String         @map("campaign_id")
  proposedBy  String         @map("proposed_by")
  dates       DateTime[]
  decidedDate DateTime?      @map("decided_date")
  status      ProposalStatus @default(OPEN)
  createdAt   DateTime       @default(now()) @map("created_at")

  campaign Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  proposer User          @relation("SessionProposalAuthor", fields: [proposedBy], references: [id], onDelete: Cascade)
  votes    SessionVote[]

  @@map("session_proposals")
}

model SessionVote {
  id         String   @id @default(uuid())
  proposalId String   @map("proposal_id")
  userId     String   @map("user_id")
  date       DateTime
  available  Boolean

  proposal SessionProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId, date])
  @@map("session_votes")
}
