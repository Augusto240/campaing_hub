generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum CampaignRole {
  GM
  PLAYER
}

enum EventType {
  BATTLE
  STORY
  NPC
  TREASURE
}

enum Rarity {
  MUNDANE
  COMMON
  UNCOMMON
  RARE
  VERY_RARE
  LEGENDARY
  ARTIFACT
  ELDRITCH
}

enum ItemType {
  WEAPON
  ARMOR
  POTION
  SCROLL
  WAND
  RING
  MISC
  MAGIC_ITEM
  CONSUMABLE
  TOME
  MYTHOS_TOME
  RELIC
}

enum WikiCategory {
  NPC
  LOCATION
  FACTION
  LORE
  HOUSE_RULE
  BESTIARY
  DEITY
  MYTHOS
  SESSION_RECAP
}

enum WikiBlockType {
  TEXT
  CHECKLIST
  QUOTE
  CALLOUT
  CODE
  IMAGE
  TABLE
}

enum ProposalStatus {
  OPEN
  DECIDED
  CANCELLED
}

enum GraphNodeType {
  WIKI_PAGE
  CHARACTER
  SESSION
  ITEM
  CREATURE
  COMPENDIUM_ENTRY
}

enum GraphEdgeType {
  WIKI_LINK
  WIKI_MENTION
  SESSION_COMBATANT
  CHARACTER_ITEM
  COMPENDIUM_REFERENCE
}

enum CoreEntityType {
  PAGE
  CHARACTER
  SESSION
  COMPENDIUM_ENTRY
  VTT_TOKEN
  LEGACY_ANCHOR
}

enum CoreRelationType {
  PARENT_OF
  LINKS_TO
  REFERENCES
  APPEARS_IN
  LOCATED_IN
}

enum CompendiumCoreKind {
  CREATURE
  SPELL
  ITEM
}

enum CompendiumCoreSource {
  SRD
  HOMEBREW
  LEGACY
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  ownedCampaigns  Campaign[]
  campaignMembers CampaignMember[]
  characters      Character[]
  notifications   Notification[]
  activityLogs    ActivityLog[]
  createdSessions Session[]
  refreshTokens   RefreshToken[]
  wikiPages       WikiPage[]       @relation("WikiPageAuthor")
  wikiFavorites   WikiFavorite[]
  diceRolls       DiceRoll[]
  creatures       Creature[]       @relation("CreatureAuthor")
  sessionProposals SessionProposal[] @relation("SessionProposalAuthor")
  sessionVotes    SessionVote[]
  corePages       CorePage[]       @relation("CorePageAuthor")
  compendiumCoreEntries CompendiumCoreEntry[] @relation("CompendiumCoreEntryAuthor")
  compendiumCoreFavorites CompendiumCoreFavorite[]
  updatedVttStates VttState[]      @relation("VttStateUpdater")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  revoked   Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token, revoked])
  @@map("refresh_tokens")
}

model RpgSystem {
  id              String   @id @default(uuid())
  name            String   @unique
  slug            String   @unique
  description     String?
  diceFormula     String   @map("dice_formula")
  attributeSchema Json     @map("attribute_schema")
  xpTable         Json?    @map("xp_table")
  hasSpellSlots   Boolean  @default(false) @map("has_spell_slots")
  hasSanity       Boolean  @default(false) @map("has_sanity")
  hasMana         Boolean  @default(false) @map("has_mana")
  hasHeroPoints   Boolean  @default(false) @map("has_hero_points")
  createdAt       DateTime @default(now()) @map("created_at")

  campaigns  Campaign[]
  characters Character[]
  items      Item[]
  creatures  Creature[]

  @@map("rpg_systems")
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  description String?
  system      String
  systemId    String?  @map("system_id")
  ownerId     String   @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  owner          User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  systemTemplate RpgSystem?       @relation(fields: [systemId], references: [id], onDelete: SetNull)
  members        CampaignMember[]
  characters     Character[]
  sessions       Session[]
  events         Event[]
  wikiPages      WikiPage[]
  diceRolls      DiceRoll[]
  sessionProposals SessionProposal[]
  knowledgeNodes KnowledgeNode[]
  knowledgeEdges KnowledgeEdge[]
  corePages CorePage[]
  coreNodes Node[]
  coreRelations CoreRelation[]
  compendiumCoreEntries CompendiumCoreEntry[]
  compendiumCoreFavorites CompendiumCoreFavorite[]
  vttState VttState?

  @@map("campaigns")
}

model CampaignMember {
  id         String       @id @default(uuid())
  campaignId String       @map("campaign_id")
  userId     String       @map("user_id")
  role       CampaignRole
  joinedAt   DateTime     @default(now()) @map("joined_at")

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("campaign_members")
}

model Character {
  id           String   @id @default(uuid())
  name         String
  class        String
  level        Int      @default(1)
  xp           Int      @default(0)
  version      Int      @default(0)
  playerId     String   @map("player_id")
  campaignId   String   @map("campaign_id")
  systemId     String?  @map("system_id")
  attributes   Json     @default("{}")
  resources    Json     @default("{}")
  inventory    Json     @default("[]")
  notes        String?
  imageUrl     String?  @map("image_url")
  sheetFileUrl String?  @map("sheet_file_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  player         User          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  campaign       Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  systemTemplate RpgSystem?    @relation(fields: [systemId], references: [id], onDelete: SetNull)
  loot           Loot[]
  sanityEvents   SanityEvent[]
  spellCasts     SpellCast[]
  diceRolls      DiceRoll[]
  combatants     Combatant[]

  @@map("characters")
}

model Session {
  id             String   @id @default(uuid())
  campaignId     String   @map("campaign_id")
  date           DateTime
  summary        String?
  narrativeLog   String?  @map("narrative_log")
  privateGmNotes String?  @map("private_gm_notes")
  highlights     String[] @default([])
  xpAwarded      Int      @default(0) @map("xp_awarded")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator      User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  loot         Loot[]
  diceRolls    DiceRoll[]
  sanityEvents SanityEvent[]
  spellCasts   SpellCast[]
  combatEncounters CombatEncounter[]
  vttStates    VttState[]

  @@map("sessions")
}

model CombatEncounter {
  id          String      @id @default(uuid())
  sessionId   String      @map("session_id")
  name        String
  isActive    Boolean     @default(true) @map("is_active")
  currentTurn Int         @default(0) @map("current_turn")
  round       Int         @default(1)
  createdAt   DateTime    @default(now()) @map("created_at")

  session     Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  combatants  Combatant[]

  @@map("combat_encounters")
}

model Combatant {
  id          String          @id @default(uuid())
  encounterId String          @map("encounter_id")
  name        String
  initiative  Int
  hp          Int
  maxHp       Int             @map("max_hp")
  isNpc       Boolean         @default(false) @map("is_npc")
  characterId String?         @map("character_id")
  conditions  String[]        @default([])
  notes       String?
  order       Int

  encounter   CombatEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  character   Character?      @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([encounterId, order])
  @@map("combatants")
}

model Loot {
  id                    String   @id @default(uuid())
  name                  String
  description           String?
  value                 Float    @default(0)
  sessionId             String   @map("session_id")
  assignedToCharacterId String?  @map("assigned_to_character_id")
  createdAt             DateTime @default(now()) @map("created_at")

  // Relations
  session             Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignedToCharacter Character? @relation(fields: [assignedToCharacterId], references: [id], onDelete: SetNull)
  lootItems           LootItem[]

  @@map("loot")
}

model Item {
  id          String   @id @default(uuid())
  name        String
  description String?
  rarity      Rarity   @default(COMMON)
  weight      Float?
  value       Int?
  itemType    ItemType @default(MISC) @map("item_type")
  systemId    String?  @map("system_id")
  properties  Json?
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")

  systemTemplate RpgSystem? @relation(fields: [systemId], references: [id], onDelete: SetNull)
  lootItems      LootItem[]

  @@map("items")
}

model LootItem {
  id       String @id @default(uuid())
  lootId   String @map("loot_id")
  itemId   String @map("item_id")
  quantity Int    @default(1)

  loot Loot @relation(fields: [lootId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([lootId, itemId])
  @@map("loot_items")
}

model Event {
  id          String    @id @default(uuid())
  campaignId  String    @map("campaign_id")
  title       String
  description String?
  eventDate   DateTime  @map("event_date")
  type        EventType
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("events")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  message   String
  read      Boolean   @default(false)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model WikiPage {
  id         String       @id @default(uuid())
  campaignId String       @map("campaign_id")
  parentPageId String?    @map("parent_page_id")
  legacySource String?    @map("legacy_source")
  title      String
  content    String
  category   WikiCategory
  tags       String[]     @default([])
  createdBy  String       @map("created_by")
  isPublic   Boolean      @default(true) @map("is_public")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  parent   WikiPage? @relation("WikiPageHierarchy", fields: [parentPageId], references: [id], onDelete: SetNull)
  children WikiPage[] @relation("WikiPageHierarchy")
  author   User     @relation("WikiPageAuthor", fields: [createdBy], references: [id], onDelete: Cascade)
  blocks   WikiBlock[]
  favorites WikiFavorite[]
  corePage CorePage?

  @@index([campaignId, category])
  @@index([campaignId, parentPageId])
  @@index([campaignId, legacySource])
  @@map("wiki_pages")
}

model WikiBlock {
  id         String       @id @default(uuid())
  wikiPageId String       @map("wiki_page_id")
  blockType  WikiBlockType @map("block_type")
  sortOrder  Int          @map("sort_order")
  payload    Json
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  page WikiPage @relation(fields: [wikiPageId], references: [id], onDelete: Cascade)

  @@index([wikiPageId, sortOrder])
  @@map("wiki_blocks")
}

model WikiFavorite {
  id         String   @id @default(uuid())
  wikiPageId String   @map("wiki_page_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  page WikiPage @relation(fields: [wikiPageId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([wikiPageId, userId])
  @@index([userId, createdAt])
  @@map("wiki_favorites")
}

model DiceRoll {
  id          String   @id @default(uuid())
  sessionId   String?  @map("session_id")
  campaignId  String   @map("campaign_id")
  userId      String   @map("user_id")
  characterId String?  @map("character_id")
  formula     String
  result      Int
  breakdown   Json
  label       String?
  isPrivate   Boolean  @default(false) @map("is_private")
  createdAt   DateTime @default(now()) @map("created_at")

  session   Session?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@map("dice_rolls")
}

model SanityEvent {
  id           String   @id @default(uuid())
  characterId  String   @map("character_id")
  sessionId    String?  @map("session_id")
  trigger      String
  sanityLost   Int      @map("sanity_lost")
  tempInsanity String?  @map("temp_insanity")
  permInsanity String?  @map("perm_insanity")
  createdAt    DateTime @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  session   Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([characterId, createdAt])
  @@map("sanity_events")
}

model SpellCast {
  id          String   @id @default(uuid())
  characterId String   @map("character_id")
  sessionId   String?  @map("session_id")
  spellName   String   @map("spell_name")
  manaCost    Int      @map("mana_cost")
  faithCost   Int      @default(0) @map("faith_cost")
  result      String?
  createdAt   DateTime @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  session   Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([characterId, createdAt])
  @@map("spell_casts")
}

model Creature {
  id           String    @id @default(uuid())
  name         String
  systemId     String    @map("system_id")
  creatureType String    @map("creature_type")
  stats        Json
  abilities    Json
  loot         Json?
  xpReward     Int?      @map("xp_reward")
  description  String?
  isPublic     Boolean   @default(false) @map("is_public")
  createdBy    String    @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  systemTemplate RpgSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
  creator        User      @relation("CreatureAuthor", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([systemId, creatureType])
  @@unique([systemId, name])
  @@map("creatures")
}

model SessionProposal {
  id          String         @id @default(uuid())
  campaignId  String         @map("campaign_id")
  proposedBy  String         @map("proposed_by")
  dates       DateTime[]
  decidedDate DateTime?      @map("decided_date")
  status      ProposalStatus @default(OPEN)
  createdAt   DateTime       @default(now()) @map("created_at")

  campaign Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  proposer User          @relation("SessionProposalAuthor", fields: [proposedBy], references: [id], onDelete: Cascade)
  votes    SessionVote[]

  @@map("session_proposals")
}

model SessionVote {
  id         String   @id @default(uuid())
  proposalId String   @map("proposal_id")
  userId     String   @map("user_id")
  date       DateTime
  available  Boolean

  proposal SessionProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId, date])
  @@map("session_votes")
}

model KnowledgeNode {
  id          String        @id @default(uuid())
  campaignId  String        @map("campaign_id")
  nodeType    GraphNodeType @map("node_type")
  sourceId    String        @map("source_id")
  label       String
  legacyAnchor Boolean      @default(false) @map("legacy_anchor")
  metadata    Json          @default("{}")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  outgoingEdges KnowledgeEdge[] @relation("KnowledgeEdgeSource")
  incomingEdges KnowledgeEdge[] @relation("KnowledgeEdgeTarget")

  @@unique([campaignId, nodeType, sourceId])
  @@index([campaignId, nodeType])
  @@map("knowledge_nodes")
}

model KnowledgeEdge {
  id          String        @id @default(uuid())
  campaignId  String        @map("campaign_id")
  edgeType    GraphEdgeType @map("edge_type")
  sourceNodeId String       @map("source_node_id")
  targetNodeId String       @map("target_node_id")
  weight      Float         @default(1)
  metadata    Json          @default("{}")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sourceNode KnowledgeNode @relation("KnowledgeEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode KnowledgeNode @relation("KnowledgeEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([campaignId, edgeType])
  @@unique([campaignId, edgeType, sourceNodeId, targetNodeId])
  @@map("knowledge_edges")
}

model CorePage {
  id           String   @id @default(uuid())
  campaignId   String   @map("campaign_id")
  wikiPageId   String?  @unique @map("wiki_page_id")
  parentPageId String?  @map("parent_page_id")
  title        String
  slug         String
  pageType     String   @default("WIKI") @map("page_type")
  summary      String?
  metadata     Json     @default("{}")
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  wikiPage  WikiPage? @relation(fields: [wikiPageId], references: [id], onDelete: SetNull)
  parent    CorePage? @relation("CorePageHierarchy", fields: [parentPageId], references: [id], onDelete: SetNull)
  children  CorePage[] @relation("CorePageHierarchy")
  creator   User     @relation("CorePageAuthor", fields: [createdBy], references: [id], onDelete: Cascade)
  nodes     Node[]

  @@unique([campaignId, slug])
  @@index([campaignId, parentPageId])
  @@map("core_pages")
}

model Node {
  id           String         @id @default(uuid())
  campaignId   String         @map("campaign_id")
  type         String         @default("MEMORY")
  title        String         @default("Untitled")
  content      Json?
  pageId       String?        @map("page_id")
  entityType   CoreEntityType @map("entity_type")
  sourceId     String         @map("source_id")
  label        String
  legacyAnchor Boolean        @default(false) @map("legacy_anchor")
  metadata     Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  page     CorePage? @relation(fields: [pageId], references: [id], onDelete: SetNull)
  relationsFrom NodeRelation[] @relation("from")
  relationsTo   NodeRelation[] @relation("to")
  sourceRelations CoreRelation[] @relation("CoreRelationSource")
  targetRelations CoreRelation[] @relation("CoreRelationTarget")

  @@unique([campaignId, entityType, sourceId])
  @@index([campaignId, entityType])
  @@index([campaignId, type])
  @@map("core_nodes")
}

model NodeRelation {
  id     String @id @default(uuid())
  fromId String @map("from_id")
  toId   String @map("to_id")
  type   String

  from Node @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  to   Node @relation("to", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, type])
  @@index([fromId])
  @@index([toId])
  @@map("node_relations")
}

model CoreRelation {
  id           String           @id @default(uuid())
  campaignId   String           @map("campaign_id")
  relationType CoreRelationType @map("relation_type")
  sourceNodeId String           @map("source_node_id")
  targetNodeId String           @map("target_node_id")
  metadata     Json             @default("{}")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sourceNode Node @relation("CoreRelationSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode Node @relation("CoreRelationTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([campaignId, relationType, sourceNodeId, targetNodeId])
  @@index([campaignId, relationType])
  @@map("core_relations")
}

model CompendiumCoreEntry {
  id         String               @id @default(uuid())
  campaignId String?              @map("campaign_id")
  systemSlug String               @map("system_slug")
  kind       CompendiumCoreKind
  source     CompendiumCoreSource @default(HOMEBREW)
  name       String
  summary    String?
  tags       String[]             @default([])
  content    Json                 @default("{}")
  createdBy  String?              @map("created_by")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator   User?     @relation("CompendiumCoreEntryAuthor", fields: [createdBy], references: [id], onDelete: SetNull)
  favorites CompendiumCoreFavorite[]

  @@index([campaignId, kind])
  @@index([systemSlug, kind, name])
  @@map("compendium_core_entries")
}

model CompendiumCoreFavorite {
  id         String   @id @default(uuid())
  entryId    String   @map("entry_id")
  campaignId String   @map("campaign_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  entry    CompendiumCoreEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  campaign Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, campaignId, userId])
  @@index([campaignId, userId])
  @@map("compendium_core_favorites")
}

model VttState {
  id          String   @id @default(uuid())
  campaignId  String   @unique @map("campaign_id")
  sessionId   String?  @map("session_id")
  mapImageUrl String?  @map("map_image_url")
  gridSize    Int      @default(56) @map("grid_size")
  tokens      Json     @default("[]")
  fogState    Json     @default("{}") @map("fog_state")
  lights      Json     @default("[]")
  metadata    Json     @default("{}")
  updatedBy   String   @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session  Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  updater  User     @relation("VttStateUpdater", fields: [updatedBy], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("vtt_states")
}
